{
  "dashboard": {
    "title": "ByteBox Overview",
    "uid": "bytebox-overview",
    "panels": [
      {
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [{"expr": "rate(bytebox_http_requests_total[5m])", "legendFormat": "{{method}} {{path}} {{status}}"}]
      },
      {
        "title": "Request Duration (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [{"expr": "histogram_quantile(0.95, rate(bytebox_http_request_duration_seconds_bucket[5m]))", "legendFormat": "{{method}} {{path}}"}]
      },
      {
        "title": "Requests In Flight",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
        "targets": [{"expr": "bytebox_http_requests_in_flight"}]
      },
      {
        "title": "Error Rate (5xx)",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
        "targets": [{"expr": "sum(rate(bytebox_http_requests_total{status=~\"5..\"}[5m]))"}]
      },
      {
        "title": "Upload Bytes (total)",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
        "targets": [{"expr": "bytebox_upload_bytes_total"}]
      },
      {
        "title": "Go Goroutines",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
        "targets": [{"expr": "go_goroutines{job=\"bytebox-api\"}"}]
      },
      {
        "title": "Upload Volume",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [{"expr": "rate(bytebox_upload_bytes_total[5m])", "legendFormat": "bytes/s"}],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          }
        }
      },
      {
        "title": "Active Users",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
        "targets": [{"expr": "bytebox_active_users", "legendFormat": "active users"}],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 50},
                {"color": "red", "value": 100}
              ]
            }
          }
        }
      },
      {
        "title": "Request Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16},
        "targets": [
          {"expr": "sum(rate(bytebox_http_requests_total{status=~\"4..\"}[5m])) / sum(rate(bytebox_http_requests_total[5m])) * 100", "legendFormat": "4xx %"},
          {"expr": "sum(rate(bytebox_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(bytebox_http_requests_total[5m])) * 100", "legendFormat": "5xx %"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "title": "API Latency by Endpoint (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [{"expr": "histogram_quantile(0.95, sum(rate(bytebox_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}"}],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "title": "Requests In-Flight",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [{"expr": "bytebox_http_requests_in_flight", "legendFormat": "in-flight"}]
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "30s"
  }
}
