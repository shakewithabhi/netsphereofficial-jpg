# ByteBox Production Environment
# Copy to .env.production and fill in values

# App
APP_ENV=production
APP_MAX_UPLOAD_SIZE=52428800

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=bytebox
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=bytebox
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_DB=0

# Storage (Cloudflare R2 — S3-compatible)
# Endpoint: https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
STORAGE_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY
STORAGE_BUCKET_FILES=bytebox-files
STORAGE_BUCKET_THUMBS=bytebox-thumbnails
STORAGE_BUCKET_TEMP=bytebox-temp
STORAGE_PRESIGN_EXPIRY=3600

# Cloudflare Stream (video transcoding + HLS streaming)
CF_STREAM_API_TOKEN=YOUR_CF_STREAM_API_TOKEN
CF_STREAM_ACCOUNT_ID=YOUR_CF_ACCOUNT_ID
CF_STREAM_CUSTOMER_SUBDOMAIN=YOUR_CUSTOMER_SUBDOMAIN
CF_STREAM_WEBHOOK_SECRET=YOUR_CF_WEBHOOK_SECRET

# Auth
AUTH_ACCESS_TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
AUTH_REFRESH_TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
AUTH_ACCESS_TOKEN_TTL_MIN=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_BCRYPT_COST=12

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URL=https://yourdomain.com/auth/google/callback

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PRICE_ID
STRIPE_PREMIUM_PRICE_ID=price_YOUR_PREMIUM_PRICE_ID

# Meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=CHANGE_ME_STRONG_MASTER_KEY

# Virus Scanning
CLAMAV_ENABLED=true

# App Base URL (for share links and billing redirects)
APP_BASE_URL=https://yourdomain.com
