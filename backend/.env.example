# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# App
APP_ENV=development
APP_DEFAULT_QUOTA_GB=5
APP_MAX_UPLOAD_SIZE_MB=10

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=bytebox
DB_PASSWORD=bytebox
DB_NAME=bytebox
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Storage (Cloudflare R2 or MinIO for local dev)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_BUCKET_FILES=bytebox-files
STORAGE_BUCKET_THUMBS=bytebox-thumbnails
STORAGE_BUCKET_TEMP=bytebox-temp

# Auth
AUTH_ACCESS_TOKEN_SECRET=change-me-in-production-access
AUTH_REFRESH_TOKEN_SECRET=change-me-in-production-refresh
AUTH_ACCESS_TOKEN_TTL_MIN=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_BCRYPT_COST=12

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# Virus Scanning
CLAMAV_ENABLED=false
